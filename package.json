{
  "name": "gpt-image-playground",
  "private": true,
  "version": "0.2.15",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "npm run test:client && npm run test:server",
    "test:client": "vitest run src",
    "test:server": "node --test server/test/auth.test.mjs server/test/httpConfig.test.mjs server/test/logger.test.mjs server/test/storage.test.mjs",
    "test:all": "npm run test:client && npm run test:server",
    "test:watch": "vitest",
    "start": "node server/server.mjs",
    "server:test": "npm run test:server"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^4.1.5"
  }
}
